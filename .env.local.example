# Google Sheets Sync Configuration
# Copy this file to .env.local and fill in the values.
# Restart the dev server after changes.

# Apps Script Web App URL (from Deploy > Web app in Apps Script)
VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared secret (must match WEBHOOK_SECRET in Apps Script > Project Settings > Script Properties)
VITE_SHEETS_WEBHOOK_SECRET=your-shared-secret-here
